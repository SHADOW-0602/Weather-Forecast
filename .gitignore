# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   Pipfile.lock might be unstable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be included in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be included in version control.
#pdm.lock

